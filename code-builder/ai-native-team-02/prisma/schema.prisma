// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// TODO: Set DATABASE_URL in .env before running migrations
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Investor {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  firm         String?
  prefsJson    Json?
  role         String    @default("INVESTOR")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  watchlists   Watchlist[]
  alerts       Alert[]
  sessions     Session[]
  accounts     Account[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  investor          Investor? @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  investor     Investor @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

model Startup {
  id               String          @id @default(cuid())
  name             String
  slug             String          @unique
  website          String?
  description      String
  longDescription  String?
  sector           String
  industry         String
  impactArea       String[]
  hq               String?
  foundedYear      Int?
  size             String?
  logoUrl          String?
  crunchbaseId     String?         @unique
  impactScore      Float?
  financialScore   Float?
  overallScore     Float?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  analyses         Analysis[]
  fundingEvents    FundingEvent[]
  watchlists       Watchlist[]
}

model Analysis {
  id           String   @id @default(cuid())
  startupId    String
  startup      Startup  @relation(fields: [startupId], references: [id], onDelete: Cascade)
  agentRole    String
  output       Json
  confidence   Float?
  sources      String[]
  createdAt    DateTime @default(now())
}

model Watchlist {
  id         String   @id @default(cuid())
  investorId String
  startupId  String
  addedAt    DateTime @default(now())
  investor   Investor @relation(fields: [investorId], references: [id], onDelete: Cascade)
  startup    Startup  @relation(fields: [startupId], references: [id], onDelete: Cascade)
  @@unique([investorId, startupId])
}

model FundingEvent {
  id          String   @id @default(cuid())
  startupId   String
  startup     Startup  @relation(fields: [startupId], references: [id], onDelete: Cascade)
  round       String
  amount      Float?
  currency    String   @default("USD")
  date        DateTime
  source      String?
  createdAt   DateTime @default(now())
}

model Alert {
  id         String    @id @default(cuid())
  investorId String
  investor   Investor  @relation(fields: [investorId], references: [id], onDelete: Cascade)
  rule       Json
  isActive   Boolean   @default(true)
  lastFired  DateTime?
  createdAt  DateTime  @default(now())
}

model AgentRun {
  id          String   @id @default(cuid())
  agentRole   String
  input       Json
  output      Json?
  status      String   @default("RUNNING")
  error       String?
  startedAt   DateTime @default(now())
  completedAt DateTime?
  metadata    Json?
}